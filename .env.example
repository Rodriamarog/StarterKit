# ============================================================
# App
# ============================================================
PUBLIC_APP_URL=http://localhost:5173

# ============================================================
# PocketBase
# https://pocketbase.io
# ============================================================
PUBLIC_POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your-admin-password

# ============================================================
# Stripe
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys
# Webhook test secret: run `stripe listen` and copy the whsec_
# Webhook live secret: Stripe dashboard → Webhooks → your endpoint
# ============================================================
STRIPE_SECRET_KEY_TEST=sk_test_your_test_secret_key_here
STRIPE_SECRET_KEY_LIVE=sk_live_your_live_secret_key_here
STRIPE_WEBHOOK_SECRET_TEST=whsec_your_test_webhook_secret_here
STRIPE_WEBHOOK_SECRET_LIVE=whsec_your_live_webhook_secret_here
